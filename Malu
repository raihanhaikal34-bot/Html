// Aktifkan Animasi AOS
AOS.init({ duration: 1000, once: true });

// Hilangkan Loading Screen saat halaman siap
window.addEventListener('load', () => {
    document.querySelector('.loader').style.display = 'none';
});

// Sticky Navbar saat Scroll
window.addEventListener('scroll', () => {
    const nav = document.querySelector('.navbar');
    if (window.scrollY > 100) {
        nav.classList.add('sticky');
    } else {
        nav.classList.remove('sticky');
    }
});

// Dark Mode Toggle
const toggle = document.getElementById('dark-mode-toggle');
toggle.addEventListener('click', () => {
    document.body.classList.toggle('dark-theme');
    if (document.body.classList.contains('dark-theme')) {
        toggle.classList.replace('fa-moon', 'fa-sun');
    } else {
        toggle.classList.replace('fa-sun', 'fa-moon');
    }
});

// Smooth Scroll untuk menu
document.querySelectorAll('.nav-links a, .hero-btns a').forEach(link => {
    link.addEventListener('click', e => {
        e.preventDefault();
        const target = document.querySelector(link.getAttribute('href'));
        window.scrollTo({
            top: target.offsetTop - 70,
            behavior: 'smooth'
        });
    });
});
