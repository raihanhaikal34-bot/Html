<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grand Horizon Hotel | Luxury & Elegance</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="loader">
        <div class="spinner"></div>
    </div>

    <nav class="navbar">
        <div class="logo">GRAND <span>HORIZON</span></div>
        <ul class="nav-links">
            <li><a href="#home">Home</a></li>
            <li><a href="#rooms">Rooms</a></li>
            <li><a href="#facilities">Facilities</a></li>
            <li><a href="#gallery">Gallery</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
        <div class="nav-extra">
            <i class="fas fa-moon" id="dark-mode-toggle"></i>
            <a href="#booking" class="btn-gold">Book Now</a>
        </div>
    </nav>

    <header id="home" class="hero">
        <div class="hero-content" data-aos="fade-up">
            <span class="subtitle">WELCOME TO LUXURY</span>
            <h1>Kemewahan Tanpa Batas</h1>
            <p>Destinasi utama untuk kenyamanan eksklusif dan pelayanan kelas dunia.</p>
            <div class="hero-btns">
                <a href="#rooms" class="btn-main">Lihat Kamar</a>
                <a href="#booking" class="btn-outline-white">Pesan Sekarang</a>
            </div>
        </div>
    </header>

    <section id="booking" class="booking-bar" data-aos="fade-up">
        <form class="booking-form">
            <div class="input-group">
                <label><i class="fas fa-calendar-alt"></i> Check-in</label>
                <input type="date" required>
            </div>
            <div class="input-group">
                <label><i class="fas fa-calendar-check"></i> Check-out</label>
                <input type="date" required>
            </div>
            <div class="input-group">
                <label><i class="fas fa-user"></i> Tamu</label>
                <select>
                    <option>1 Orang</option>
                    <option>2 Orang</option>
                    <option>Family (4+)</option>
                </select>
            </div>
            <div class="input-group">
                <label><i class="fas fa-bed"></i> Kamar</label>
                <select>
                    <option>Standard</option>
                    <option>Deluxe</option>
                    <option>Suite</option>
                </select>
            </div>
            <button type="submit" class="btn-gold">Konfirmasi</button>
        </form>
    </section>

    <section id="rooms" class="section">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Kamar Pilihan Kami</h2>
            <div class="room-grid">
                <div class="room-card" data-aos="fade-up">
                    <div class="room-img" style="background-image: url('https://images.unsplash.com/photo-1611892440504-42a792e24d32?auto=format&fit=crop&q=80&w=600')"></div>
                    <div class="room-body">
                        <h3>Standard Room</h3>
                        <p class="price">Rp 850.000 / Malam</p>
                        <ul class="room-features">
                            <li><i class="fas fa-wifi"></i> Free Wifi</li>
                            <li><i class="fas fa-coffee"></i> Breakfast</li>
                        </ul>
                        <button class="btn-gold-full">Booking</button>
                    </div>
                </div>
                <div class="room-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="room-img" style="background-image: url('https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&q=80&w=600')"></div>
                    <div class="room-body">
                        <h3>Deluxe Room</h3>
                        <p class="price">Rp 1.500.000 / Malam</p>
                        <ul class="room-features">
                            <li><i class="fas fa-tv"></i> Smart TV</li>
                            <li><i class="fas fa-wind"></i> AC & Bathub</li>
                        </ul>
                        <button class="btn-gold-full">Booking</button>
                    </div>
                </div>
                <div class="room-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="room-img" style="background-image: url('https://images.unsplash.com/photo-1631049307264-da0ec9d70304?auto=format&fit=crop&q=80&w=600')"></div>
                    <div class="room-body">
                        <h3>Suite Room</h3>
                        <p class="price">Rp 3.500.000 / Malam</p>
                        <ul class="room-features">
                            <li><i class="fas fa-city"></i> City View</li>
                            <li><i class="fas fa-wine-glass"></i> Mini Bar</li>
                        </ul>
                        <button class="btn-gold-full">Booking</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="facilities" class="section bg-light">
        <div class="container">
            <h2 class="section-title">Fasilitas Eksklusif</h2>
            <div class="facilities-grid">
                <div class="fac-item" data-aos="zoom-in">
                    <i class="fas fa-swimmer"></i>
                    <h4>Infinity Pool</h4>
                </div>
                <div class="fac-item" data-aos="zoom-in" data-aos-delay="100">
                    <i class="fas fa-utensils"></i>
                    <h4>Restoran Bintang 5</h4>
                </div>
                <div class="fac-item" data-aos="zoom-in" data-aos-delay="200">
                    <i class="fas fa-spa"></i>
                    <h4>Spa & Wellness</h4>
                </div>
                <div class="fac-item" data-aos="zoom-in" data-aos-delay="300">
                    <i class="fas fa-dumbbell"></i>
                    <h4>Gym Center</h4>
                </div>
            </div>
        </div>
    </section>

    <section id="gallery" class="section">
        <div class="container">
            <h2 class="section-title">Gallery</h2>
            <div class="gallery-grid">
                <div class="gal-img" style="background-image: url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&q=80&w=400')" data-aos="fade-up"></div>
                <div class="gal-img" style="background-image: url('https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?auto=format&fit=crop&q=80&w=400')" data-aos="fade-up"></div>
                <div class="gal-img" style="background-image: url('https://images.unsplash.com/photo-1544161515-4ad6ce6ca85d?auto=format&fit=crop&q=80&w=400')" data-aos="fade-up"></div>
                <div class="gal-img" style="background-image: url('https://images.unsplash.com/photo-1571896349842-33c89424de2d?auto=format&fit=crop&q=80&w=400')" data-aos="fade-up"></div>
            </div>
        </div>
    </section>

    <section id="about" class="section bg-blue text-white">
        <div class="container about-container">
            <div class="about-text" data-aos="fade-right">
                <h2>Tentang Grand Horizon</h2>
                <p>Didirikan dengan visi memberikan pengalaman menginap yang tak terlupakan. Kami menggabungkan arsitektur modern dengan keramahan lokal yang hangat.</p>
                <p><b>Visi:</b> Menjadi hotel ikonik di cakrawala kota.</p>
                <p><b>Misi:</b> Menyediakan layanan personalisasi bagi setiap tamu.</p>
            </div>
            <div class="about-img" data-aos="fade-left">
                <img src="https://images.unsplash.com/photo-1445019980597-93fa8acb246c?auto=format&fit=crop&q=80&w=500" alt="About Hotel">
            </div>
        </div>
    </section>

    <section id="contact" class="section">
        <div class="container contact-wrapper">
            <div class="contact-form" data-aos="fade-up">
                <h3>Hubungi Kami</h3>
                <input type="text" placeholder="Nama Lengkap">
                <input type="email" placeholder="Email">
                <textarea placeholder="Pesan Anda"></textarea>
                <button class="btn-gold-full">Kirim Pesan</button>
            </div>
            <div class="contact-info" data-aos="fade-up" data-aos-delay="200">
                <h3>Info Kontak</h3>
                <p><i class="fas fa-map-marker-alt"></i> Jl. Horizon Indah No. 1, Tangerang</p>
                <p><i class="fas fa-phone"></i> +62 21 1234 5678</p>
                <p><i class="fas fa-envelope"></i> info@grandhorizon.com</p>
                <div class="map-placeholder">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d126916.0373859897!2d106.60251141320573!3d-6.246194639918236!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69fbc2b37c6031%3A0xc665e89d89758e5e!2sTangerang%2C%20Kota%20Tangerang%2C%20Banten!5e0!3m2!1sid!2sid!4v1700000000000" style="border:0; width:100%; height:200px;" allowfullscreen="" loading="lazy"></iframe>
                </div>
            </div>
        </div>
    </section>

    <footer>
        <div class="footer-grid container">
            <div>
                <h3>GRAND HORIZON</h3>
                <p>Luxury and Comfort in one place.</p>
                <div class="socials">
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-facebook"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                </div>
            </div>
            <div class="footer-links">
                <h4>Link Cepat</h4>
                <ul>
                    <li><a href="#home">Home</a></li>
                    <li><a href="#rooms">Rooms</a></li>
                    <li><a href="#about">About Us</a></li>
                </ul>
            </div>
            <div class="newsletter">
                <h4>Newsletter</h4>
                <p>Dapatkan info promo menarik.</p>
                <div class="subs">
                    <input type="email" placeholder="Email">
                    <button class="btn-gold">Join</button>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="script.js"></script>
</body>
</html>
